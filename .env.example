# Financial Advisor AI - Environment Variables
# Copy to .env and fill in your keys: cp .env.example .env

# Required: OpenAI is used for embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Required: Anthropic is used for the chat/generation model
ANTHROPIC_API_KEY=

# Optional: Tavily for real-time web search (not yet wired into the backend)
TAVILY_API_KEY=

# Optional: Redis URL for production session memory (falls back to in-memory dicts)
REDIS_URL=
